# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependency directories
node_modules/
jspm_packages/

# Distribution directories
dist/
build/
out/
es/
.next/ # For Next.js projects
.vite/ # For Vite projects

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Environments
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Typescript v1 declaration files
typings/

# Temp
.tempUserDataDir

# Code coverage
coverage/
*.lcov

# Editor/OS-specific files (optional, can be in a global gitignore)
.DS_Store # macOS
.idea/ # JetBrains IDEs
.vscode/ # VS Code (only if you want to ignore specific workspace settings)
*.suo
*.user
*.lock.json # Package-lock.json and yarn.lock should typically be committed, but other lock files might be ignored

